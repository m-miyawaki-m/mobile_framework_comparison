@startuml 7_native_jetpack_stack

title 【⑦ ネイティブ】 Jetpack コンポーネント構成

skinparam defaultFontName "Meiryo"

package "UI Layer" as UI #C8E6C9 {
  component "Jetpack Compose\n(androidx.compose.*)" as COMPOSE
  component "Navigation Compose\n(androidx.navigation)" as NAV
  component "ViewModel\n(androidx.lifecycle)" as VM
  component "StateFlow\n(kotlinx.coroutines)" as FLOW
}

package "Dependency Injection" as DI #F5F5F5 {
  component "Hilt\n(dagger.hilt)" as HILT
}

package "Domain Layer" as DOMAIN #DCEDC8 {
  component "UseCase" as UC
}

package "Data Layer" as DATA #E6EE9C {
  component "Repository" as REPO
  component "Room\n(androidx.room)" as ROOM
  component "DataStore\n(androidx.datastore)" as DATASTORE
  component "Retrofit / OkHttp / Ktor" as HTTP
  component "WorkManager\n(androidx.work)" as WM
  component "Paging 3\n(androidx.paging)" as PAGING
}

package "Cross-cutting" as CC #ECEFF1 {
  component "Coroutines\n(kotlinx.coroutines)" as COROUTINES
  component "Serialization\n(kotlinx.serialization)" as SER
  component "Timber\n(log)" as LOG
}

package "Security" as SEC #FFCDD2 {
  component "Jetpack Security\n(EncryptedSharedPrefs\nEncryptedFile)" as JSEC
  component "Biometric" as BIO
  component "Keystore / Play Integrity" as KEY
}

COMPOSE --> NAV
COMPOSE --> VM
VM --> FLOW
VM --> UC
UC --> REPO
REPO --> ROOM
REPO --> DATASTORE
REPO --> HTTP
REPO --> WM
REPO --> PAGING

HILT ..> VM : inject
HILT ..> UC : inject
HILT ..> REPO : inject

COROUTINES ..> VM
COROUTINES ..> REPO
SER ..> HTTP

REPO --> JSEC
REPO --> KEY
VM --> BIO

@enduml
